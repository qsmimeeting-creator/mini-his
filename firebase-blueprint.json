{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "A registered patient",
      "type": "object",
      "properties": {
        "hn": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "birthDate": { "type": "string" },
        "gender": { "type": "string" },
        "citizenId": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "addressLine1": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "drugAllergy": { "type": "string" },
        "foodAllergy": { "type": "string" },
        "vaccineAllergy": { "type": "string" },
        "underlyingDisease": { "type": "string" },
        "currentMedication": { "type": "string" },
        "paymentType": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["hn", "name", "firstName", "lastName", "birthDate", "gender", "citizenId", "phone"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A patient visit record",
      "type": "object",
      "properties": {
        "vn": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string" },
        "visitType": { "type": "string" },
        "data": { "type": "object" }
      },
      "required": ["vn", "patientId", "patientName", "status", "timestamp", "visitType", "data"]
    },
    "Vaccine": {
      "title": "Vaccine",
      "description": "Vaccine inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "genericName": { "type": "string" },
        "manufacturer": { "type": "string" },
        "type": { "type": "string" },
        "lot": { "type": "string" },
        "receivedDate": { "type": "string" },
        "expiryDate": { "type": "string" },
        "unitCost": { "type": "number" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "reorderLevel": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["name", "type", "lot", "expiryDate", "unitCost", "price", "stock", "reorderLevel", "unit"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": { "$ref": "#/entities/Patient" },
      "description": "Patients collection"
    },
    "/visits/{visitId}": {
      "schema": { "$ref": "#/entities/Visit" },
      "description": "Visits collection"
    },
    "/vaccines/{vaccineId}": {
      "schema": { "$ref": "#/entities/Vaccine" },
      "description": "Vaccines collection"
    }
  }
}
